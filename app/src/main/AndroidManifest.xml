<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name=".activity.ExpenseActivity"
            android:parentActivityName=".activity.MajorActivity"
            android:theme="@style/expenseTheme"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".activity.RevenueActivity"
            android:parentActivityName=".activity.MajorActivity"
            android:theme="@style/revenueTheme"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".activity.MajorActivity"
            android:label="@string/title_activity_major"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".activity.RegisterActivity"
            android:parentActivityName=".activity.MainActivity" />
        <activity
            android:name=".activity.LoginActivity"
            android:parentActivityName=".activity.MainActivity" />
        <activity
            android:name=".activity.MainActivity"
            android:theme="@style/Theme.Intro"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>